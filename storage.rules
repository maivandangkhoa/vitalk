rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Blog images - authenticated upload, public read
    match /blog-covers/{fileName} {
      allow read;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /blog-images/{allPaths=**} {
      allow read;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Teacher profile images - authenticated upload, public read
    match /teacher-profiles/{fileName} {
      allow read;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
