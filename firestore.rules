rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isTeacher() {
      return hasRole("teacher");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isTeacherOwner(teacherId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/teachers/$(teacherId)).data.uid == request.auth.uid;
    }

    function getUserTeacherId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId;
    }

    // Profile - legacy, kept for backward compat
    match /profile/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Teachers - public read, admin create/delete, teacher+admin update own
    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isTeacherOwner(teacherId);
      allow delete: if isAdmin();

      // Teacher's availability subcollection
      match /availability/{monthId} {
        allow read: if true;
        allow create, delete: if isAdmin() || isTeacherOwner(teacherId);
        allow update: if isAuthenticated();
      }
    }

    // Lesson Types - public read, admin write
    match /lessonTypes/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy availability - kept for migration period
    match /availability/{monthId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated() || isAdmin();
    }

    // Users - own doc read/write, admin read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings - students create + read own, teacher read/update own, admin full access
    match /bookings/{bookingId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.studentId == request.auth.uid)
        || (isTeacher() && isAuthenticated() && resource.data.teacherId == getUserTeacherId());
      allow update: if isAdmin()
        || (isTeacher() && isAuthenticated() && resource.data.teacherId == getUserTeacherId());
      allow delete: if isAdmin();
    }

    // Reviews - public read visible, auth create, teacher+admin manage own, student reads own
    match /reviews/{reviewId} {
      allow read: if resource.data.isVisible == true || isAdmin()
        || (isTeacher() && isAuthenticated() && resource.data.teacherId == getUserTeacherId())
        || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin()
        || (isTeacher() && isAuthenticated() && resource.data.teacherId == getUserTeacherId());
    }

    // Blog Posts - public read published, admin write
    match /blogPosts/{postId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Blog Post Summaries - public read, only Cloud Functions write
    match /blogPostSummaries/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Locations - public read, admin write
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site Config - public read, admin write
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Mail - only Cloud Functions (deny all client access)
    match /mail/{mailId} {
      allow read, write: if false;
    }

    // Notifications - users read/update own (mark-as-read), Cloud Functions write
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
  }
}
